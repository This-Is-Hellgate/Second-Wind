{
  "name": "second-wind",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Second Wind — the exact AWS tool an agent needs from GitHub, without downloading all the bullshit. x402 USDC on Base.",
  "dependencies": {
    "@x402/evm": "^2.17.0",
    "@x402/extensions": "^2.17.0",
    "@x402/hono": "^2.17.0",
    "aws4fetch": "^1.0.20",
    "hono": "^4.12.29",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@x402/core": "^2.17.0",
    "@x402/fetch": "^2.17.0",
    "ajv": "^8.20.0",
    "esbuild": "^0.28.1"
  },
  "scripts": {
    "build:worker": "esbuild src/worker.js --bundle --format=esm --outfile=public/_worker.js --platform=browser --conditions=workerd,worker,browser --minify-syntax --alias:url=node:url --alias:buffer=node:buffer --external:node:*",
    "selftest": "node scripts/selftest.mjs && node scripts/worker-selftest.mjs"
  }
}
