{
  "openapi": "3.1.0",
  "info": {
    "title": "Second Wind \u2014 AWS knowledge catalog for autonomous agents",
    "summary": "Pre-launch API surface. Paid catalog doors deliver curated AWS operational knowledge via x402 (USDC on Base).",
    "description": "Second Wind sells the map, not the territory: distilled diagnostics, recipes, and construct routing for open-source AWS tooling, priced $0.03\u2013$0.25 USDC per item, session-less via x402 v2. This document describes the launch API; endpoints go live on secondwindai.com.",
    "version": "0.1.0",
    "x-audience": "autonomous_agents",
    "x-status": "pre-launch",
    "contact": {
      "url": "https://secondwindai.com/llms.txt",
      "email": "info@secondeyesai.com"
    }
  },
  "servers": [
    {
      "url": "https://secondwindai.com"
    }
  ],
  "x-payment": {
    "rail": "x402",
    "x402Version": 2,
    "asset": "USDC",
    "scheme": "ExactEvmScheme",
    "active_networks": [
      "eip155:8453"
    ],
    "requirements_header": "PAYMENT-REQUIRED",
    "payment_header": "PAYMENT-SIGNATURE"
  },
  "components": {
    "securitySchemes": {
      "x402Payment": {
        "type": "http",
        "scheme": "payment",
        "description": "x402 v2 payment. First call returns 402 with a PAYMENT-REQUIRED header carrying accepts[]. Sign USDC on Base (eip155:8453) via ExactEvmScheme and retry with the PAYMENT-SIGNATURE header."
      }
    }
  },
  "paths": {
    "/api/catalog": {
      "get": {
        "operationId": "catalog_get",
        "summary": "Browse the live catalog (free).",
        "tags": [
          "free",
          "discovery"
        ],
        "security": [],
        "parameters": [
          {
            "name": "service",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Optional. Filter by canonical service slug, e.g. 'lambda', 'sagemaker', 'ruby'."
          },
          {
            "name": "type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "tool",
                "construct",
                "diagnostic",
                "recipe",
                "template",
                "manifest",
                "decision",
                "cost-model",
                "auth-flow"
              ]
            },
            "description": "Optional. Filter by item type."
          }
        ],
        "responses": {
          "200": {
            "description": "Live catalog items with sku, slug, price, and one-line lead."
          }
        }
      }
    },
    "/api/proof": {
      "get": {
        "operationId": "proof_get",
        "summary": "Self-check \u2014 verify Second Wind is live before paying (free).",
        "tags": [
          "free",
          "discovery"
        ],
        "security": [],
        "responses": {
          "200": {
            "description": "Liveness and payment-rail posture."
          }
        }
      }
    },
    "/api/x402/{sku}": {
      "get": {
        "operationId": "item_get",
        "summary": "Buy one catalog item, session-less via x402.",
        "tags": [
          "paid",
          "x402"
        ],
        "security": [
          {
            "x402Payment": []
          }
        ],
        "x-payment-info": {
          "rail": "x402",
          "x402Version": 2,
          "asset": "USDC",
          "network": "eip155:8453",
          "scheme": "ExactEvmScheme",
          "price_usd": "per-item; see /api/catalog"
        },
        "parameters": [
          {
            "name": "sku",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Catalog item SKU, e.g. 'AWS-0573'."
          }
        ],
        "responses": {
          "200": {
            "description": "Paid delivery: the item's distilled knowledge, source pointer, license, and content hash.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "sku": {
                      "type": "string"
                    },
                    "slug": {
                      "type": "string"
                    },
                    "summary": {
                      "type": "string",
                      "description": "The deliverable \u2014 distilled operational knowledge."
                    },
                    "source_repo": {
                      "type": "string"
                    },
                    "source_url": {
                      "type": "string"
                    },
                    "license_spdx": {
                      "type": "string"
                    },
                    "content_hash": {
                      "type": "string"
                    },
                    "access": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "sku",
                    "summary",
                    "access"
                  ],
                  "additionalProperties": true
                }
              }
            }
          },
          "402": {
            "description": "Payment Required \u2014 read the PAYMENT-REQUIRED header for the x402 accepts[] and pay via USDC on Base."
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "paid",
      "description": "Session-less x402 paid doors (USDC on Base)."
    },
    {
      "name": "x402",
      "description": "x402 v2 payment-required doors."
    },
    {
      "name": "free",
      "description": "Free, unpaid surfaces."
    },
    {
      "name": "discovery",
      "description": "Discovery and proof surfaces."
    }
  ]
}
